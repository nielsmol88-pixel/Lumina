# ─── Supabase (EU region: Frankfurt — mandatory for GDPR Art. 9) ────────────
# Get these from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # Server-side only — NEVER expose to client or commit

# ─── Notifications ──────────────────────────────────────────────────────────────
MAKE_WEBHOOK_URL=https://hook.eu1.make.com/YOUR_WEBHOOK_ID
# OR use Telegram:
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_CHAT_ID

# ─── WhatsApp (WATI or Twilio) ──────────────────────────────────────────────────
WATI_API_ENDPOINT=https://live-server.wati.io/api/v1
WATI_API_TOKEN=YOUR_WATI_TOKEN
# Twilio alternative:
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=YOUR_AUTH_TOKEN
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── App ────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── WhatsApp Webhook Security ──────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
WATI_WEBHOOK_SECRET=your-random-secret-here
